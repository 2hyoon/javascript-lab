{
  "name": "javascript-lab",
  "version": "1.0.0",
  "description": "",
  "main": "index.js",
  "scripts": {
    "dev": "NODE_ENV=development webpack --watch --config ./webpack.config.js",
    "prod": "NODE_ENV=production webpack --config webpack.config.js",
    "lint:js": "eslint \"src/scripts/**/*.js\" \"*.js\"",
    "lint:sass": "stylelint \"src/styles/**/*.{scss,sass}\"",
    "lint": "npm run lint:js && npm run lint:sass",
    "prettier:check": "prettier --check \"src/{html,scripts,styles}/**/*.{html,scss,js,json}\" \"*.{js,json}\"",
    "prettier:write": "prettier --write \"src/{html,scripts,styles}/**/*.{html,scss,js,json}\" \"*.{js,json}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/2hyoon/javascript-lab.git"
  },
  "keywords": [
    "webpack",
    "vanila",
    "javascript",
    "scss"
  ],
  "author": "Hailey Yoon",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/2hyoon/javascript-lab/issues"
  },
  "homepage": "https://github.com/2hyoon/javascript-lab#readme",
  "devDependencies": {
    "@babel/core": "^7.28.4",
    "@babel/preset-env": "^7.28.3",
    "autoprefixer": "^10.4.21",
    "babel-loader": "^10.0.0",
    "browser-sync": "^3.0.4",
    "browser-sync-webpack-plugin": "^2.4.0",
    "clean-webpack-plugin": "^4.0.0",
    "copy-webpack-plugin": "^13.0.1",
    "cross-env": "^10.1.0",
    "css-loader": "^7.1.2",
    "eslint": "^8.57.1",
    "eslint-config-airbnb-base": "^15.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "handlebars-webpack-plugin": "^2.2.1",
    "install": "^0.13.0",
    "mini-css-extract-plugin": "^2.9.4",
    "npm": "^11.6.2",
    "postcss-loader": "^8.2.0",
    "prettier": "^3.6.2",
    "sass": "^1.93.2",
    "sass-loader": "^16.0.5",
    "style-loader": "^4.0.0",
    "stylelint": "^16.25.0",
    "stylelint-config-sass-guidelines": "^12.1.0",
    "stylelint-config-standard": "^39.0.1",
    "webpack": "^5.102.1",
    "webpack-cli": "^6.0.1",
    "webpack-dev-server": "^5.2.2"
